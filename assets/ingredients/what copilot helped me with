function renderIngredients() {
  ingredientsPanel.innerHTML = "";
  for (const ingredient of ingredients) {
    const button = document.createElement("button");
    button.type = "button";
    button.className = "ingredient-btn";
    button.dataset.ingredient = ingredient.id;
    button.innerHTML = `
      <img class="ingredient-thumb" src="${ingredient.image}" alt="${ingredient.label}" />
      <span class="ingredient-label">
        ${ingredient.label}
        <small>${ingredient.short}</small>
      </span>
    `;
    button.addEventListener("click", () => addIngredient(ingredient));
    ingredientsPanel.appendChild(button);
  }
}


